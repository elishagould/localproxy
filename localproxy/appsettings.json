{
  "Proxy": {
    "Port": 3128,
    "EnableUpstreamProxy": true,
    "BufferSize": 8192,
    "NoProxy": [
      "localhost",
      "127.0.0.1",
      "*.local",
      "192.168.*",
      "10.*"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "Console": {
      "Enabled": true
    },
    "File": {
      "Enabled": true,
      "Path": "logs/proxy-.log",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 7
    }
  },
  "Authentication": {
    "EnableCaching": true,
    "TimeoutSeconds": 30
  }
}
